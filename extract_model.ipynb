   "source": [
    "import torch\n",
    "from vggt.models.vggt import VGGT"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "2ba01caa",
   "metadata": {},
   "outputs": [],
   "source": [
    "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "6a1cc96d",
   "metadata": {},
   "outputs": [],
   "source": [
    "model = VGGT.from_pretrained(\"facebook/VGGT-1B\").to(DEVICE)\n",
    "model = model.half()\n",
    "model.eval()\n",
    "\n",
    "torch.save(model.state_dict(), \"vggt_fp16.pth\")"
   ]
  },
